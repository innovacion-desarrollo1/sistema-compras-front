<mat-card class="ranking-card">
  <mat-card-header>
    <mat-card-title>
      <mat-icon>store</mat-icon>
      Supplier Ranking (80/20 Score)
    </mat-card-title>
    <mat-card-subtitle>
      Suppliers ranked by real net cost (80%) + KPI performance (20%)
    </mat-card-subtitle>
  </mat-card-header>

  <mat-card-content>
    <!-- Loading State -->
    <div *ngIf="isLoading" class="loading-container">
      <mat-spinner diameter="40"></mat-spinner>
      <p>Loading supplier ranking...</p>
    </div>

    <!-- Ranking Table -->
    <div *ngIf="!isLoading && suppliers.length > 0" class="table-container">
      <table mat-table [dataSource]="suppliers" class="supplier-table">
        
        <!-- Ranking Column -->
        <ng-container matColumnDef="ranking">
          <th mat-header-cell *matHeaderCellDef>Ranking</th>
          <td mat-cell *matCellDef="let supplier; let i = index">
            <div class="ranking-badge" [ngClass]="{'top-supplier': isTopSupplier(i)}">
              #{{ i + 1 }}
            </div>
          </td>
        </ng-container>
        
        <!-- Supplier Name Column -->
        <ng-container matColumnDef="nombre">
          <th mat-header-cell *matHeaderCellDef>Proveedor</th>
          <td mat-cell *matCellDef="let supplier">
            <div class="supplier-name">
              {{ supplier.proveedor_nombre }}
              <span class="supplier-id">(ID: {{ supplier.proveedor_id }})</span>
            </div>
          </td>
        </ng-container>
        
        <!-- Real Net Cost Column -->
        <ng-container matColumnDef="costo_real_neto">
          <th mat-header-cell *matHeaderCellDef>Costo Real Neto</th>
          <td mat-cell *matCellDef="let supplier">
            <div class="cost-display">
              <strong>${{ supplier.costo_real_neto | number:'1.0-0' }}</strong>
              <mat-icon class="cost-breakdown" 
                        [matTooltip]="'Precio Lista: $' + (supplier.precio_lista | number:'1.0-0') + ' - Bonificaciones: $' + (supplier.bonificaciones_total | number:'1.0-0')">
                info
              </mat-icon>
            </div>
          </td>
        </ng-container>
        
        <!-- KPI Score Column -->
        <ng-container matColumnDef="kpi_score">
          <th mat-header-cell *matHeaderCellDef>KPI Performance</th>
          <td mat-cell *matCellDef="let supplier">
            <div class="kpi-display">
              <mat-progress-bar 
                mode="determinate" 
                [value]="supplier.kpi_score"
                [ngClass]="getKpiClass(supplier.kpi_score)">
              </mat-progress-bar>
              <span class="kpi-value">{{ supplier.kpi_score | number:'1.0-1' }}/100</span>
            </div>
            <div class="kpi-breakdown">
              <span [matTooltip]="'On-Time In-Full: ' + (supplier.otif | number:'1.0-1') + '%'">
                OTIF: {{ supplier.otif | number:'1.0-1' }}%
              </span>
              <span [matTooltip]="'Lead Time Compliance: ' + (supplier.lt_compliance | number:'1.0-1') + '%'">
                LT: {{ supplier.lt_compliance | number:'1.0-1' }}%
              </span>
            </div>
          </td>
        </ng-container>
        
        <!-- Final Score Column -->
        <ng-container matColumnDef="score_final">
          <th mat-header-cell *matHeaderCellDef>Score Final</th>
          <td mat-cell *matCellDef="let supplier">
            <span class="score-badge">{{ supplier.score_final_80_20 | number:'1.2-2' }}</span>
            <span class="score-hint">(menor es mejor)</span>
          </td>
        </ng-container>
        
        <!-- Governance Column -->
        <ng-container matColumnDef="governance">
          <th mat-header-cell *matHeaderCellDef>Gobernanza</th>
          <td mat-cell *matCellDef="let supplier; let i = index">
            <mat-chip [ngClass]="'semaphore-chip-' + getSemaphoreColor(supplier, i)">
              {{ getSemaphoreText(supplier, i) }}
            </mat-chip>
          </td>
        </ng-container>
        
        <!-- Actions Column -->
        <ng-container matColumnDef="actions">
          <th mat-header-cell *matHeaderCellDef>Acciones</th>
          <td mat-cell *matCellDef="let supplier">
            <button mat-raised-button 
                    color="primary"
                    (click)="selectSupplier(supplier)"
                    [disabled]="supplier.requiere_aprobacion">
              Seleccionar
            </button>
          </td>
        </ng-container>
        
        <!-- Header Row -->
        <tr mat-header-row *matHeaderRowDef="displayedColumns"></tr>
        
        <!-- Data Rows -->
        <tr mat-row 
            *matRowDef="let row; let i = index; columns: displayedColumns;" 
            [ngClass]="{'top-supplier-row': isTopSupplier(i)}">
        </tr>
        
      </table>
    </div>

    <!-- Empty State -->
    <div *ngIf="!isLoading && suppliers.length === 0" class="empty-state">
      <mat-icon>search_off</mat-icon>
      <p>No se encontraron proveedores para este producto</p>
    </div>
  </mat-card-content>
</mat-card>
